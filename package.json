{
  "name": "caara",
  "version": "1.0.0",
  "description": "CAARA: Context-Aware Autonomous Research Agent with hybrid retrieval, verification, and optimization layers",
  "main": "src/app.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/app.ts",
    "start": "bun run src/app.ts",
    "build": "tsc",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "bun test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "axios": "^1.14.0",
    "bullmq": "^5.73.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18"
  }
}
